@{
    ViewData["Title"] = "Home - Chotti Vijini Luxury Hotel";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-overlay">
        <div class="hero-content">
            <h1 class="hero-title">Experience Serenity in the Hills of Uttarakhand</h1>
            <p class="hero-subtitle">A Luxury Mountain View Hotel Experience Awaits You</p>
            <div class="hero-buttons">
                <a href="/Contact" class="btn btn-success btn-lg me-2">
                    <i class="fas fa-envelope"></i> Inquire Now
                </a>
                <a href="#facilities" class="btn btn-outline-light btn-lg">
                    <i class="fas fa-arrow-down"></i> Learn More
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Opening Banner -->
<section class="opening-banner py-3 bg-warning text-center">
    <h3 class="mb-0">
        <i class="fas fa-calendar-alt"></i> Opening in 6 Months – Stay Tuned! 
        <i class="fas fa-calendar-alt"></i>
    </h3>
</section>

<!-- Hotel Overview Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4">
                <h2 class="section-title mb-4">Welcome to VIDHISHA</h2>
                <p class="lead">Nestled in the serene hills of Uttarakhand, VIDHISHA is a luxury mountain view hotel designed for those seeking peace, adventure, and unforgettable experiences.</p>
                
                <div class="highlights mt-4">
                    <div class="highlight-item mb-3">
                        <h5><i class="fas fa-door-open text-success"></i> 100 Luxury Rooms</h5>
                        <p>Thoughtfully designed rooms with panoramic mountain views and modern amenities.</p>
                    </div>
                    <div class="highlight-item mb-3">
                        <h5><i class="fas fa-mountain text-success"></i> Mountain View</h5>
                        <p>Wake up to breathtaking views of the Himalayan mountains from your balcony.</p>
                    </div>
                    <div class="highlight-item mb-3">
                        <h5><i class="fas fa-ring text-success"></i> Destination Weddings</h5>
                        <p>Host your dream wedding in paradise with complete hospitality support.</p>
                    </div>
                    <div class="highlight-item mb-3">
                        <h5><i class="fas fa-tree text-success"></i> Nature Retreat</h5>
                        <p>Escape the chaos and reconnect with nature in our peaceful sanctuary.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="placeholder-image">
                    <img src="" alt="Hotel Overview" class="img-fluid rounded shadow-lg">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Facilities Section -->
<section id="facilities" class="py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Our Premium Facilities</h2>
        <div class="row">
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-ring"></i>
                    </div>
                    <h4>Destination Wedding Venue</h4>
                    <p>Celebrate your special day with a perfect blend of nature and luxury.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-utensils"></i>
                    </div>
                    <h4>Restaurant & Dining</h4>
                    <p>Savor authentic and international cuisines in a scenic mountain setting.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-mountain"></i>
                    </div>
                    <h4>Mountain View Rooms</h4>
                    <p>Luxurious rooms with private balconies overlooking the Himalayas.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-car"></i>
                    </div>
                    <h4>Parking</h4>
                    <p>Secure and spacious parking facilities for all our guests.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h4>Event Lawn</h4>
                    <p>Open-air venue for conferences, celebrations, and outdoor events.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="facility-card">
                    <div class="facility-icon">
                        <i class="fas fa-concierge-bell"></i>
                    </div>
                    <h4>24/7 Guest Service</h4>
                    <p>Round-the-clock service to ensure your stay is perfect and comfortable.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Location Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="section-title text-center mb-5">Strategic Location</h2>
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4">
                <div class="placeholder-image">
                    <img src="" alt="Location" class="img-fluid rounded shadow-lg">
                </div>
            </div>
            <div class="col-lg-6">
                <h4 class="mb-3">Chotti Vijini, Yamkeshwar, Uttarakhand</h4>
                <p class="lead">Located approximately 1 hour from Rishikesh, our hotel sits in a pristine mountain location surrounded by natural beauty.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><strong><i class="fas fa-check text-success"></i> Close to Rishikesh:</strong> Gateway to adventure and spirituality</li>
                    <li class="mb-2"><strong><i class="fas fa-check text-success"></i> Peaceful Environment:</strong> Far from the hustle and bustle</li>
                    <li class="mb-2"><strong><i class="fas fa-check text-success"></i> Natural Beauty:</strong> Surrounded by mountains and forests</li>
                    <li class="mb-2"><strong><i class="fas fa-check text-success"></i> Well Connected:</strong> Easy road access from major cities</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5 bg-success text-white">
    <div class="container text-center">
        <h2 class="mb-4">Ready to Experience Paradise?</h2>
        <p class="lead mb-4">Bookings will start shortly. Leave your inquiry today to be among the first guests.</p>
        <a href="/Contact" class="btn btn-light btn-lg">
            <i class="fas fa-envelope"></i> Inquire Now
        </a>
    </div>
</section>
