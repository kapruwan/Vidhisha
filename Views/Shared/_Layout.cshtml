<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VIDHISHA Luxury Hotel</title>
    <meta name="description" content="Luxury Mountain View Hotel in Uttarakhand - VIDHISHA, Yamkeshwar">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vidhisha.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation Bar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-hotel"></i> VIDHISHA
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-end">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="About" asp-action="Index">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Rooms">Rooms</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main role="main" class="main-content pt-5">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer mt-5 py-5 bg-dark text-white">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <h5><i class="fas fa-hotel"></i> Chotti Vijini</h5>
                    <p>Luxury Mountain View Hotel in Uttarakhand</p>
                    <p><strong class="text-warning"><i class="fas fa-clock"></i> Opening in 6 Months</strong></p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Contact Info</h5>
                    <p>
                        <i class="fas fa-map-marker-alt"></i> Chotti Vijini, Yamkeshwar, Uttarakhand<br>
                        <i class="fas fa-phone"></i> +91-XXXX-XXXX-XX<br>
                        <i class="fas fa-envelope"></i> info@chottvijini.com
                    </p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-white">Home</a></li>
                        <li><a href="/About" class="text-white">About Us</a></li>
                        <li><a href="/Home/Rooms" class="text-white">Rooms</a></li>
                        <li><a href="/Contact" class="text-white">Contact Us</a></li>
                    </ul>
                </div>
            </div>
            <hr class="bg-white">
            <div class="text-center">
                <p>&copy; 2026 Vidhisha Luxury Hotel. All rights reserved. | <strong>Opening Soon</strong></p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
