@{
    ViewData["Title"] = "About - Bidisha Luxury Hotel";
}

<div style="margin-top: 80px;"></div>

<!-- Page Header -->
<section class="page-header bg-dark text-white py-5">
    <div class="container">
        <h1 class="display-4">About Bidisha</h1>
        <p class="lead">Discover Our Story and Vision</p>
    </div>
</section>

<!-- Our Story Section -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4">
                <h2 class="section-title mb-4">Our Story</h2>
                <p class="lead">
                    Bidisha is envisioned as a luxury mountain retreat that brings together the finest hospitality with nature's tranquility. Our project is currently under construction and is set to be a game-changer in the Uttarakhand tourism industry.
                </p>
                <p>
                    Located in the serene hills of Yamkeshwar, approximately one hour from the spiritual haven of Rishikesh, Bidisha will offer an unparalleled experience of luxury, peace, and adventure. We are building more than just a hotel; we are creating a sanctuary for those seeking to escape the ordinary.
                </p>
                <p>
                    With 100 thoughtfully designed luxury rooms, world-class amenities, and a commitment to sustainability, Bidisha will redefine mountain hospitality.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="placeholder-image">
                    <img src="@Url.Content("~/Images/image11.jpeg")" alt="Under Construction" class="img-fluid rounded shadow-lg">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Location Benefits -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="section-title text-center mb-5">Why Bidisha?</h2>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="fas fa-map-marked-alt"></i>
                    </div>
                    <h4>Strategic Location</h4>
                    <p>Positioned in the heart of Uttarakhand's natural beauty, close enough to Rishikesh for accessibility yet far enough to offer complete tranquility. Easily accessible by road from Delhi and major cities.</p>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="fas fa-tree"></i>
                    </div>
                    <h4>Peaceful Environment</h4>
                    <p>Surrounded by lush green forests, pristine mountains, and flowing streams. Away from the chaos of city life, our hotel provides a perfect escape for relaxation and rejuvenation.</p>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="fas fa-mountain"></i>
                    </div>
                    <h4>Adventure Hub</h4>
                    <p>Close to adventure activities like trekking, rafting, paragliding, and more. Perfect base for exploring the beautiful Himalayan trails and outdoor experiences.</p>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <i class="fas fa-ring"></i>
                    </div>
                    <h4>Wedding Destination</h4>
                    <p>Ideal backdrop for destination weddings and special events. Scenic beauty combined with luxury amenities makes it perfect for memorable celebrations.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Construction & Timeline -->
<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Construction Status</h2>
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="construction-info bg-light p-5 rounded">
                    <h4 class="mb-3">
                        <i class="fas fa-hard-hat text-warning"></i> Currently Under Construction
                    </h4>
                    <p class="lead">
                        <strong>Expected Opening: In 6 Months</strong>
                    </p>
                    <div class="progress mb-3" style="height: 30px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 65%;" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100">
                            <strong>65% Complete</strong>
                        </div>
                    </div>
                    <p>
                        Our construction is progressing rapidly with top-quality materials and expert workforce. We are building a world-class facility that will set new standards for luxury hospitality in the region.
                    </p>
                    <p class="text-muted">
                        <i class="fas fa-info-circle"></i> <strong>Bookings will commence once the hotel is ready for operations.</strong>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Vision Section -->
<section class="py-5 bg-dark text-white vision-section">
    <div class="container">
        <h2 class="section-title text-center mb-5 text-white">Our Vision</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="vision-item text-center">
                    <i class="fas fa-star" style="font-size: 3rem; color: #ffc107;"></i>
                    <h4 class="mt-3">Excellence</h4>
                    <p>Delivering world-class service and luxury in every aspect of guest experience.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="vision-item text-center">
                    <i class="fas fa-leaf" style="font-size: 3rem; color: #28a745;"></i>
                    <h4 class="mt-3">Sustainability</h4>
                    <p>Committed to eco-friendly practices and preserving the natural beauty of Uttarakhand.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="vision-item text-center">
                    <i class="fas fa-heart" style="font-size: 3rem; color: #dc3545;"></i>
                    <h4 class="mt-3">Hospitality</h4>
                    <p>Creating memorable experiences through personalized service and warm hospitality.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-success text-white cta-section">
    <div class="container text-center">
        <h2 class="mb-4">Be Among the First</h2>
        <p class="lead mb-4">Register your interest to receive updates and be notified when bookings open.</p>
        <a href="/Contact" class="btn btn-light btn-lg">
            <i class="fas fa-envelope"></i> Express Interest
        </a>
    </div>
</section>
